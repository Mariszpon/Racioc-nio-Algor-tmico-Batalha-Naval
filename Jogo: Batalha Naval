# - - - Função: limpar_tela - - -
def limpar_tela():
    # Essa função limpa o terminal pra deixar a tela organizada.
    # 'cls' funciona no Windows, 'clear' funciona no Linux/Mac.
    # O os.name retorna 'nt' se for Windows, então usamos isso pra decidir qual comando rodar!
    os.system('cls' if os.name == 'nt' else 'clear')

# - - - Função: animar_canhao - - -
def animar_canhao(acertou=True):
    # Essa função mostra uma animação de canhão atirando no terminal!
    # Se acertou=True, aparece BOOM! com a explosão.
    # Se acertou=False, aparece splash com a bala caindo na água.

    # Cada item da lista é um frame da animação.
    # O canhão aponta pra direita e a bala vai viajando até o alvo!
    frames = [
        # Frame 1 — canhão parado, antes de atirar
        [
            "                                        ",
            "   ____                                 ",
            "  |    |                                ",
            "  |====]                                ",
            "  |____|                                ",
            " /  ()  \\                              ",
            "----------                              ",
        ],
        # Frame 2 — disparo! bala saindo
        [
            "                                        ",
            "   ____                                 ",
            "  |    |                                ",
            "  |====] o                              ",
            "  |____|                                ",
            " /  ()  \\                              ",
            "----------                              ",
        ],
        # Frame 3 — bala viajando
        [
            "                                        ",
            "   ____                                 ",
            "  |    |                                ",
            "  |====]       o                        ",
            "  |____|                                ",
            " /  ()  \\                              ",
            "----------                              ",
        ],
        # Frame 4 — bala quase chegando
        [
            "                                        ",
            "   ____                                 ",
            "  |    |                                ",
            "  |====]              o                 ",
            "  |____|                                ",
            " /  ()  \\                              ",
            "----------                              ",
        ],
        # Frame 5 — impacto (será preenchido abaixo dependendo do resultado)
        [],
    ]

    # Define o frame de impacto com base no resultado do tiro
    if acertou:
        frames[4] = [
            "                                        ",
            "   ____                                 ",
            "  |    |                      * BOOM! * ",
            "  |====]                   ***  X  ***  ",
            "  |____|                      *****     ",
            " /  ()  \\                              ",
            "----------                              ",
        ]
    else:
        frames[4] = [
            "                                        ",
            "   ____                                 ",
            "  |    |                                ",
            "  |====]                   splash~      ",
            "  |____|                    ~~~o~~~     ",
            " /  ()  \\                              ",
            "----------                              ",
        ]

    # Velocidade entre os frames em segundos.
    # Os primeiros frames são mais rápidos pra parecer que a bala está voando!
    velocidades = [0.4, 0.2, 0.2, 0.2, 0.6]

    # Roda a animação frame a frame
    # enumerate nos dá o índice (i) e o frame ao mesmo tempo
    for i, frame in enumerate(frames):
        limpar_tela()
        for linha in frame:
            print(linha)
        time.sleep(velocidades[i])

    # Após a animação, mostra a mensagem final de acerto ou erro
    limpar_tela()
    if acertou:
        print("\n  💥 DIRETO NO ALVO! Embarcação atingida!\n")
    else:
        print("\n  🌊 Errou! A bala caiu na água...\n")

    time.sleep(1)

