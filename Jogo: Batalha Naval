# - - - Função: escolher_modo - - -
def escolher_modo():
    # Essa função fica em loop até o jogador digitar um número válido (entre 1 e 3).
    # Quando o jogador acertar, ela retorna o número escolhido pro programa usar!

    verify = 0
    # Enquanto verify for 0, o programa continua pedindo uma escolha
    while verify == 0:
        try:
            # Tenta converter o que o jogador digitou em número inteiro
            gameMode = int(input("\033[33m➢ 𝕾𝖊𝖑𝖊𝖈𝖎𝖔𝖓𝖊 𝖔 𝖒𝖔𝖉𝖔 𝖉𝖊 𝖏𝖔𝖌𝖔: \033[0m"))

            if 3 >= gameMode > 0:
                # Se o número estiver entre 1 e 3, é válido!
                # Muda o verify pra 1 e o loop termina
                verify = verify + 1
            else:
                # Se o número existir mas for 0 ou maior que 3, mostra erro
                print()
                print("\033[34m➢ 𝖁𝖆𝖑𝖔𝖗 𝖎𝖓𝖛𝖆́𝖑𝖎𝖉𝖔 !! ☠︎︎\033[0m")
                print()

        except ValueError:
            # Se o jogador digitou uma letra ou símbolo (não é número), cai aqui
            # O ValueError acontece quando o int() não consegue converter o texto
            print()
            print("\033[34m➢ 𝖁𝖆𝖑𝖔𝖗 𝖎𝖓𝖛𝖆́𝖑𝖎𝖉𝖔 !! ☠︎︎\033[0m")
            print()

    # Retorna o modo escolhido pro resto do programa usar
    return gameMode

# - - - Função: main - - -
def main():
    # Essa é a função principal que controla tudo!
    # Ela mostra o menu, pega a escolha do jogador e chama o modo certo.

    exibir_menu()
    gameMode = escolher_modo()

    if gameMode == 1:
        # Modo Fácil: navios de 1 célula, PC ataca aleatoriamente
        modo_facil()
    elif gameMode == 2:
        # Modo Padrão: navios de tamanhos variados, afunda só quando todas as partes forem atingidas
        modo_padrao()
